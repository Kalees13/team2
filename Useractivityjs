/* ---------- RENDER TABLE ---------- */

function renderTable(data = activities){

    tableBody.innerHTML = "";

    data.forEach((activity,index)=>{

        let statusClass = "success";

        if(activity.status === "Pending"){

            statusClass = "pending";

        }

        if(activity.status === "Failed"){

            statusClass = "failed";

        }

        tableBody.innerHTML += `

        <tr>

            <td>${activity.id}</td>

            <td>

                <div class="user-info">

                    <img src="https://i.pravatar.cc/40?img=${index+15}" alt="User">

                    <div>

                        <h4>${activity.user}</h4>

                        <span>${activity.email}</span>

                    </div>

                </div>

            </td>

            <td>${activity.role}</td>

            <td>${activity.action}</td>

            <td>${activity.module}</td>

            <td>${activity.ip}</td>

            <td>${activity.datetime}</td>

            <td>

                <span class="status ${statusClass}">

                    ${activity.status}

                </span>

            </td>

            <td>

                <button
                    class="view-btn"
                    data-index="${index}">

                    <i class="fa-solid fa-eye"></i>

                </button>

            </td>

        </tr>

        `;

    });

}

/* ---------- INITIAL LOAD ---------- */

document.addEventListener("DOMContentLoaded",()=>{

    renderTable();

});
