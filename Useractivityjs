/* ---------- LIVE SEARCH ---------- */

searchInput.addEventListener("keyup", function () {

    const keyword = this.value.toLowerCase();

    const filteredActivities = activities.filter(activity => {

        return (

            activity.id.toLowerCase().includes(keyword) ||

            activity.user.toLowerCase().includes(keyword) ||

            activity.email.toLowerCase().includes(keyword) ||

            activity.role.toLowerCase().includes(keyword) ||

            activity.action.toLowerCase().includes(keyword) ||

            activity.module.toLowerCase().includes(keyword) ||

            activity.status.toLowerCase().includes(keyword)

        );

    });

    renderTable(filteredActivities);

});


/* ---------- REFRESH BUTTON ---------- */

refreshBtn.addEventListener("click", () => {

    searchInput.value = "";

    renderTable();

    showToast("Activity log refreshed successfully.");

});


/* ---------- EXPORT CSV ---------- */

exportBtn.addEventListener("click", () => {

    let csv = "Activity ID,User,Email,Role,Action,Module,IP Address,Date & Time,Status\n";

    activities.forEach(activity => {

        csv += `${activity.id},${activity.user},${activity.email},${activity.role},${activity.action},${activity.module},${activity.ip},${activity.datetime},${activity.status}\n`;

    });

    const blob = new Blob([csv], {

        type: "text/csv"

    });

    const url = URL.createObjectURL(blob);

    const link = document.createElement("a");

    link.href = url;

    link.download = "User_Activity_Report.csv";

    document.body.appendChild(link);

    link.click();

    document.body.removeChild(link);

    URL.revokeObjectURL(url);

    showToast("Activity report exported successfully.");

});


/* ---------- TOAST ---------- */

function showToast(message) {

    toast.querySelector("span").textContent = message;

    toast.classList.add("show");

    setTimeout(() => {

        toast.classList.remove("show");

    }, 3000);

}
