/* ---------- MODAL DETAIL ELEMENTS ---------- */

const activityId = document.getElementById("activityId");
const activityUser = document.getElementById("activityUser");
const activityEmail = document.getElementById("activityEmail");
const activityRole = document.getElementById("activityRole");
const activityModule = document.getElementById("activityModule");
const activityAction = document.getElementById("activityAction");
const activityTime = document.getElementById("activityTime");
const activityIP = document.getElementById("activityIP");

const deleteModal = document.getElementById("deleteModal");
const cancelDelete = document.getElementById("cancelDelete");
const confirmDelete = document.getElementById("confirmDelete");

let selectedIndex = null;

/* ---------- VIEW ACTIVITY DETAILS ---------- */

document.addEventListener("click", function (e) {

    const viewBtn = e.target.closest(".view-btn");

    if (!viewBtn) return;

    selectedIndex = Number(viewBtn.dataset.index);

    const activity = activities[selectedIndex];

    activityId.textContent = activity.id;
    activityUser.textContent = activity.user;
    activityEmail.textContent = activity.email;
    activityRole.textContent = activity.role;
    activityModule.textContent = activity.module;
    activityAction.textContent = activity.action;
    activityTime.textContent = activity.datetime;
    activityIP.textContent = activity.ip;

    activityModal.classList.add("active");

});


/* ---------- CLOSE ACTIVITY MODAL ---------- */

function closeActivityModal(){

    activityModal.classList.remove("active");

}

closeModalBtn.addEventListener("click", closeActivityModal);

closeActivityBtn.addEventListener("click", closeActivityModal);


/* ---------- CLICK OUTSIDE TO CLOSE ---------- */

window.addEventListener("click", function(e){

    if(e.target === activityModal){

        closeActivityModal();

    }

    if(e.target === deleteModal){

        deleteModal.classList.remove("active");

    }

});


