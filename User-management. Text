        <h2>Delete User?</h2>

        <p>

            Are you sure you want to delete this user?

            This action cannot be undone.

        </p>

        <div class="delete-actions">

            <button
                class="cancel-delete"
                id="cancelDelete">

                Cancel

            </button>

            <button
                class="confirm-delete"
                id="confirmDelete">

                Delete

            </button>

        </div>

    </div>

</div>



